# Copy to .env and fill in. Set the same MSSQL_* vars in Netlify (Site settings →
# Environment variables) for the deployed functions.

# SQL Server (hy_datawarehouse) — the application database
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=hy_datawarehouse
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=true

# One-time migration source (Neon/PostgreSQL). Only needed for `npm run db:migrate`.
SOURCE_DATABASE_URL=

# Email (Resend) — optional
RESEND_API_KEY=
RESEND_FROM=HealYou Health Coaching <onboarding@resend.dev>
